#!/usr/bin/env bash
# scc: sandboxed Claude Code
# Source-available under PolyForm Noncommercial 1.0.0 (see LICENSE):
# free for noncommercial use. Commercial use needs a separate license.
#
# NOTICE: independent, UNOFFICIAL project, not affiliated with Anthropic and
# does not own or control Claude Code. It runs Anthropic's official CLI unmodified.
#
# Thin dispatcher: locate lib/, load config, guard OS, route to a subcommand.
# Run assembly is in lib/docker.sh. In-container setup in entrypoint.sh.
# Resolved settings below are consumed by the sourced modules, so a static
# check can't see their use across the dynamic source: silence SC2034.
# shellcheck disable=SC2034
set -euo pipefail

SCC_SELF="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
SCC_DIR="${SCC_DIR:-$HOME/.scc}"

# Prefer lib/ next to this script (running from the repo, no reinstall needed),
# otherwise the installed copy under ~/.scc/lib.
if [[ -d "$SCC_SELF/lib" ]]; then SCC_LIB="$SCC_SELF/lib"; else SCC_LIB="$SCC_DIR/lib"; fi
[[ -d "$SCC_LIB" ]] \
  || { echo "scc: cannot find lib/ (looked in $SCC_SELF/lib and $SCC_DIR/lib)" >&2; exit 1; }

# Build context for `docker build`: the repo if present, else installed files.
if [[ -f "$SCC_SELF/Dockerfile" ]]; then SCC_BUILD_DIR="$SCC_SELF"; else SCC_BUILD_DIR="$SCC_DIR"; fi

# Load modules, then every subcommand.
# shellcheck disable=SC1090,SC1091
for _m in ui common config firewall docker toolchains project; do . "$SCC_LIB/$_m.sh"; done
# shellcheck disable=SC1090,SC1091
for _c in "$SCC_LIB"/commands/*.sh; do . "$_c"; done
unset _m _c

# scc's own version, from the VERSION file shipped next to the launcher (repo)
# or into ~/.scc by install.sh. Consumed by `scc version` and the help heading.
if [[ -f "$SCC_SELF/VERSION" ]]; then SCC_VERSION_STR="$(scc_trim "$(<"$SCC_SELF/VERSION")")"
elif [[ -f "$SCC_DIR/VERSION" ]]; then SCC_VERSION_STR="$(scc_trim "$(<"$SCC_DIR/VERSION")")"
else SCC_VERSION_STR="unknown"; fi

# Resolve settings: built-in defaults < config file < environment.
scc_config_load

# A leading global --profile NAME selects a separate home volume (so it is
# resolved before VOLUME) and applies to every subcommand, including login.
# Env/config give the default. A leading flag overrides.
SCC_PROFILE="$(scc_resolve profile SCC_PROFILE "")"
while true; do
  case "${1:-}" in
    --profile)   shift; [ $# -gt 0 ] || scc_die "--profile needs a name"; SCC_PROFILE="$1"; shift ;;
    --profile=*) SCC_PROFILE="${1#*=}"; shift ;;
    *)           break ;;
  esac
done
if [[ -n "$SCC_PROFILE" && ! "$SCC_PROFILE" =~ ^[A-Za-z0-9_-]+$ ]]; then
  scc_die "invalid profile name '$SCC_PROFILE' (letters, digits, - and _ only)"
fi

# Default image: the published GHCR image for this repo, lowercased as GHCR
# requires. This gives the fast "pull, don't build" path out of the box;
# scc_ensure_image falls back to a local build if the pull fails (private
# package, offline, or a fork). Override with SCC_IMAGE or config `image`.
SCC_DEFAULT_REPO="SensitiveWebUser/Sandbox-Claude-Code"
_repo_lc="$(printf '%s' "${SCC_REPO:-$SCC_DEFAULT_REPO}" | tr '[:upper:]' '[:lower:]')"
SCC_DEFAULT_IMAGE="ghcr.io/${_repo_lc}:latest"
unset _repo_lc

IMAGE="$(scc_resolve image SCC_IMAGE "$SCC_DEFAULT_IMAGE")"
VOLUME="$(scc_resolve volume SCC_VOLUME "scc-home${SCC_PROFILE:+-$SCC_PROFILE}")"
PIDS_LIMIT="$(scc_resolve pids_limit SCC_PIDS_LIMIT "2048")"
EXTRA_DOMAINS="$(scc_resolve extra_domains FIREWALL_EXTRA_DOMAINS "")"
EXTRA_DOCKER_ARGS="$(scc_resolve docker_args SCC_DOCKER_ARGS "")"

cmd="${1:-}"

# help and version need neither docker nor a supported OS.
case "$cmd" in
  help|-h|--help)       cmd_help; exit 0 ;;
  version|--version|-V) printf 'scc %s\n' "$SCC_VERSION_STR"; exit 0 ;;
esac

scc_guard_os

# uninstall removes files and (optionally) docker objects. It must run even
# when docker is already gone, so it is exempt from the docker requirement.
case "$cmd" in
  uninstall)   shift; cmd_uninstall "$@"; exit 0 ;;
  trust)       shift; cmd_trust "$@"; exit 0 ;;
  init)        shift; cmd_init "$@"; exit 0 ;;
  self-update) shift; cmd_self_update "$@"; exit 0 ;;
esac

scc_require_docker

case "$cmd" in
  profiles)       cmd_profiles ;;
  rebuild|build)  cmd_rebuild ;;
  update)         cmd_update ;;
  login)          cmd_login ;;
  shell)          shift; cmd_shell "$@" ;;
  yolo)           shift; cmd_yolo "$@" ;;
  *)              cmd_run "$@" ;;   # everything else passes straight to claude
esac
